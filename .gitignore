# Generated outputs -- scripts write flat to the repo root (run_pipeline.sh
# runs every step with the repo root as cwd), not into an outputs/
# subdirectory. Root-only patterns, does not affect data/ or expected_outputs/.
/*.csv
/*.png
/*.pdf

# Raw fetched data -- regenerate via src/fetch_data.py, don't commit
# (keep CHECKSUMS.sha256 tracked so the pinned vintage is verifiable)
data/*.csv
data/*.CSV
!data/CHECKSUMS.sha256

# static derived inputs -- not raw French data, not regenerated by any script
# here, so they must stay tracked despite the /*.csv rule above:
#   portfolio_factor_loadings.csv -- full-sample FF4 OLS betas per portfolio,
#     used only to sort/annotate Table 4 & 5 summaries
#   campbell_thompson_full_trainfilt.csv -- preserved Cell B (identification
#     design, filtered probs) reference output; src/ct_decomposition.py
#     verifies its own Cell B rebuild against this file (non-fatal if absent)
!/portfolio_factor_loadings.csv
!/campbell_thompson_full_trainfilt.csv

# Environment
venv/
__pycache__/
*.pyc
.ipynb_checkpoints/
.DS_Store
